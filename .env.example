# ==============================================================================
# GALAXY FULL-POWER PRODUCTION CONFIGURATION (TEMPLATE)
# ==============================================================================

# 1. CORE IDENTITY & BRANDING
GALAXY_BRAND=Galaxy Enterprise (Full Power)
GALAXY_DOMAIN=localhost
GALAXY_PORT=8080

# 2. SECURITY & AUTHENTICATION (MUST BE CHANGED!)
GALAXY_ADMIN_USERS=admin@your-org.com
GALAXY_BOOTSTRAP_ADMIN_API_KEY=CHANGEME_SECURE_TOKEN
GALAXY_ID_SECRET=CHANGEME_SECURE_HEX

# 3. SERVICE MANAGEMENT
NONUSE=

# 4. PERFORMANCE & RESOURCE SCALING
GUNICORN_WORKERS=4
CELERY_WORKERS=2
GALAXY_HANDLER_NUMPROCS=2

# 5. NETWORKING & HTTPS (DISABLED)
USE_HTTPS=False
USE_HTTPS_LETSENCRYPT=False
PROXY_PREFIX=

# 6. DOCKER & CLUSTER INTEGRATION
GALAXY_DOCKER_ENABLED=True
GALAXY_DOCKER_VOLUMES=""
DOCKER_PARENT=True
GALAXY_DESTINATIONS_DEFAULT=slurm_cluster

# 7. LOGGING & AUDITING
GALAXY_LOGGING=full

# 8. ADVANCED / DEVELOPMENT MODE
BARE=False
ENABLE_TTS_INSTALL=False
LOAD_GALAXY_CONDITIONAL_DEPENDENCIES=False
LOAD_PYTHON_DEV_DEPENDENCIES=False
GALAXY_AUTO_UPDATE_DB=True
GALAXY_EXPORT_MARKER=
